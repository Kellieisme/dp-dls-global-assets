# See http://help.github.com/ignore-files/ for more about ignoring files.

.env
.npmrc

#Token service generated files
src/js/variables.js
src/js/variablesBase.js
src/js/variables.module.js
src/js/variablesBase.module.js
src/json/variables.json
src/json/variablesBase.json
#Token service generated icons
src/images/icons/*
