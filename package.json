{
  "author": "BGS Digital Aviation Design System",
  "name": "@jeppesen-foreflight/dls-global-assets",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "version": "4.0.2",
  "description": "Atmosphere global assets",
  "homepage": "https://github.com/jeppesen-foreflight/dp-dls-global-assets",
  "browserslist": [
    "last 2 versions",
    "> 5%"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "dls",
    "web",
    "react",
    "angular"
  ],
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/jeppesen-foreflight/dp-dls-global-assets.git"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "webpack --config configuration/webpack.dev.config.js --mode=development",
    "watch": "webpack --config configuration/webpack.dev.config.js --mode=development --watch",
    "start": "webpack serve --config configuration/webpack.dev.config.js --mode=development",
    "release": "webpack --config configuration/webpack.prod.config.js --mode=production",
    "stats": "webpack --config configuration/webpack.prod.config.js --mode=production --json > dist/stats.json && webpack-bundle-analyzer dist/stats.json"
  },
  "target": "web",
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.2",
    "postcss": "^8.5.1",
    "postcss-loader": "^8.1.1",
    "sass": "^1.89.0",
    "sass-loader": "^16.0.6",
    "terser-webpack-plugin": "^5.3.11",
    "webpack": "^5.97.1",
    "webpack-bundle-analyzer": "^5.0.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2",
    "webpack-merge": "^6.0.1",
    "webpack-remove-empty-scripts": "^1.0.4"
  }
}
